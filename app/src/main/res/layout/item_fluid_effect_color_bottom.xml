<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/item_fluid_effect_color_bottom"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/fluid_effect_color_bottom"
        android:textColor="@color/ui_text_primary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/text_fluid_color_bottom_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10dp"
        android:textColor="@color/ui_text_secondary"
        android:textSize="12sp" />

    <View
        android:id="@+id/swatch_fluid_bottom"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="10dp" />

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:contentDescription="@string/content_desc_icon"
        android:rotation="270"
        android:src="@drawable/ic_expand_more"
        app:tint="@color/ui_text_secondary" />
</LinearLayout>
