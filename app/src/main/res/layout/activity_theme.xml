<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_background"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="@color/ui_header_background"
        android:fitsSystemWindows="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="@string/content_desc_icon"
            android:focusable="true"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/ui_header_text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="?attr/actionBarSize"
            android:layout_marginStart="32dp"
            android:gravity="center_vertical"
            android:text="@string/header_theme"
            android:textColor="@color/ui_header_text"
            android:textSize="20sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_current_color"
                android:textColor="@color/ui_text_secondary"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="12dp"
                android:paddingBottom="20dp">

                <View
                    android:id="@+id/preview_swatch"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_theme_swatch" />

                <TextView
                    android:id="@+id/text_current_hex"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:textColor="@color/ui_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_section_presets"
                android:textColor="@color/ui_text_secondary"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/preset_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_section_custom"
                android:textColor="@color/ui_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/theme_custom_hint"
                android:textColor="@color/ui_text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/edit_red"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_edit_text"
                    android:ems="3"
                    android:gravity="center"
                    android:hint="@string/theme_red"
                    android:inputType="number"
                    android:maxLength="3"
                    android:textColor="@color/ui_text_primary"
                    android:textColorHint="@color/ui_text_secondary" />

                <EditText
                    android:id="@+id/edit_green"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_edit_text"
                    android:ems="3"
                    android:gravity="center"
                    android:hint="@string/theme_green"
                    android:inputType="number"
                    android:maxLength="3"
                    android:textColor="@color/ui_text_primary"
                    android:textColorHint="@color/ui_text_secondary" />

                <EditText
                    android:id="@+id/edit_blue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_edit_text"
                    android:ems="3"
                    android:gravity="center"
                    android:hint="@string/theme_blue"
                    android:inputType="number"
                    android:maxLength="3"
                    android:textColor="@color/ui_text_primary"
                    android:textColorHint="@color/ui_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:id="@+id/custom_preview_swatch"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_theme_swatch" />

                <TextView
                    android:id="@+id/text_custom_hex"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:textColor="@color/ui_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_apply_custom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/theme_apply_custom"
                    android:textColor="@android:color/white" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
